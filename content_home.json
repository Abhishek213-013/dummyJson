  "faq": [
    {
      "question": "What is included in the rent?",
      "answer": "Rent includes WiFi, water, electricity, maintenance, and access to all common facilities (study lounge, gym, entertainment room). Meals are available at an additional cost."
    },
    {
      "question": "Can I book a room before arriving in Sylhet?",
      "answer": "Yes! You can book online through our website. We also offer virtual tours for prospective residents who are not in Sylhet yet."
    },
    {
      "question": "Is there any security deposit?",
      "answer": "Yes, a refundable security deposit equal to one month's rent is required at the time of booking."
    },
    {
      "question": "Can I switch rooms if I don't like mine?",
      "answer": "Subject to availability, you can request a room change after the first month. A small administrative fee may apply."
    },
    {
      "question": "Are visitors allowed?",
      "answer": "Visitors are allowed during daytime hours (8 AM - 8 PM) with prior registration at the front desk. Overnight guests are not permitted."
    }
  ],
